{
  "compilerOptions": {
    "module":           "commonjs",
    "target":           "ES2020",
    "lib":              ["ES2020"],
    "strict":           true,
    "noImplicitAny":    true,
    "esModuleInterop":  true,
    "outDir":           "lib",
    "rootDir":          "src",
    "sourceMap":        true,
    "skipLibCheck":     true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
