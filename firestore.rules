rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções auxiliares ──────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function familyData(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)).data;
    }

    function isMember(familyId) {
      return isAuth() && request.auth.uid in familyData(familyId).members;
    }

    function isOwner(familyId) {
      return isAuth() && familyData(familyId).ownerId == request.auth.uid;
    }

    function isValidCents(field) {
      return field is int && field > 0;
    }

    // ── /families/{familyId} ───────────────────────────────────────────────

    match /families/{familyId} {
      // Qualquer autenticado pode ler: necessário para buscar família por
      // invite code no fluxo de ingresso. Dados sensíveis ficam nas
      // subcollections, todas protegidas por isMember.
      allow read: if isAuth();

      allow create: if isAuth()
        // Criador deve ser o dono e estar em members
        && request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.members
        // Plano sempre começa free — cliente nunca se auto-promove
        && request.resource.data.plan == 'free';

      // Dono pode atualizar qualquer campo.
      // Não-dono pode SOMENTE se adicionar ao array members (fluxo de convite):
      //   - não pode estar em members antes
      //   - só pode adicionar exatamente si mesmo (+1 elemento)
      //   - não pode remover membros existentes
      //   - não pode alterar nenhum outro campo
      allow update: if isOwner(familyId)
        || (
          isAuth()
          && !resource.data.members.hasAny([request.auth.uid])
          && request.resource.data.members.hasAny([request.auth.uid])
          && request.resource.data.members.size() == resource.data.members.size() + 1
          && request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
        );

      // Famílias nunca são deletadas pelo app
      allow delete: if false;

      // ── /members/{memberId} ─────────────────────────────────────────────

      match /members/{memberId} {
        allow read: if isMember(familyId);

        // Usuário pode criar o próprio documento (memberId == uid).
        // Cobre dois cenários:
        //   1) Criação de família via batch (família ainda não comitada, isMember falha)
        //   2) Ingresso via invite code (execução sequencial após updateDoc)
        allow create: if isAuth() && memberId == request.auth.uid;

        // Atualização e exclusão: apenas o dono
        allow update, delete: if isOwner(familyId);
      }

      // ── /categories/{categoryId} ────────────────────────────────────────

      match /categories/{categoryId} {
        allow read, create, update: if isMember(familyId);
        allow delete: if isMember(familyId)
          && (!resource.data.isDefault || isOwner(familyId));
      }

      // ── /fixedExpenses/{expenseId} ──────────────────────────────────────

      match /fixedExpenses/{expenseId} {
        allow read: if isMember(familyId);

        allow create: if isMember(familyId)
          && isValidCents(request.resource.data.amountCents);

        allow update: if isMember(familyId)
          && isValidCents(request.resource.data.amountCents);

        allow delete: if isMember(familyId);
      }

      // ── /transactions/{transactionId} ───────────────────────────────────

      match /transactions/{transactionId} {
        allow read: if isMember(familyId);

        allow create: if isMember(familyId)
          && request.auth.uid == request.resource.data.authorId
          && isValidCents(request.resource.data.amountCents)
          && (
            request.resource.data.source == 'manual'
            || (
              // Materialização client-side de gastos fixos
              request.resource.data.source == 'fixed'
              && request.resource.data.fixedExpenseId is string
              && exists(/databases/$(database)/documents/families/$(familyId)/fixedExpenses/$(request.resource.data.fixedExpenseId))
            )
          );

        // Só o autor edita; source e fixedExpenseId são imutáveis
        allow update: if isMember(familyId)
          && resource.data.authorId == request.auth.uid
          && request.resource.data.source == resource.data.source
          && request.resource.data.fixedExpenseId == resource.data.fixedExpenseId;

        // Qualquer membro da família pode deletar — necessário para excluirFixed (batch)
        allow delete: if isMember(familyId);
      }

      // ── /monthlyReports/{reportId} ──────────────────────────────────────

      match /monthlyReports/{reportId} {
        // Leitura pelos membros; escrita exclusiva da Cloud Function (Admin SDK)
        allow read:  if isMember(familyId);
        allow write: if false;
      }
    }
  }
}
